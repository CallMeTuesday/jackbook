# Database (Railway PostgreSQL — use DATABASE_PUBLIC_URL from Railway Postgres service)
DATABASE_URL="postgresql://user:password@host:port/dbname"

# NextAuth
NEXTAUTH_SECRET="generate with: openssl rand -base64 32"
NEXTAUTH_URL="https://your-railway-domain.up.railway.app"

# Google OAuth (console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# YouTube Data API v3 (console.cloud.google.com → APIs & Services → Library → YouTube Data API v3)
YOUTUBE_API_KEY="your-youtube-api-key"
NEXT_PUBLIC_HAS_YT_KEY="true"
