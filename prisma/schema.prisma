// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Local dev: provider = "sqlite", url = "file:./dev.db"
  // Production: provider = "postgresql", url = env("DATABASE_URL")
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Move {
  id          String       @id @default(cuid())
  name        String       @unique
  slug        String       @unique
  style       String       @default("house")
  featured    Boolean      @default(false)
  thumbnail   String?
  createdAt   DateTime     @default(now())
  videoCache  VideoCache?
  submissions Submission[]
}

model VideoCache {
  id        String   @id @default(cuid())
  moveId    String   @unique
  videos    String   // JSON array of YouTubeVideo[]
  fetchedAt DateTime @default(now())
  move      Move     @relation(fields: [moveId], references: [id])
}


model User {
  id                 String       @id @default(cuid())
  name               String?
  email              String?      @unique
  emailVerified      DateTime?
  image              String?
  username           String?      @unique
  profilePublic      Boolean      @default(true)
  stripeCustomerId   String?
  subscriptionStatus String?      @default("free")
  accounts           Account[]
  sessions           Session[]
  submissions        Submission[]
  savedVideos        SavedVideo[]
}

model SavedVideo {
  id           String   @id @default(cuid())
  userId       String
  moveId       String
  moveName     String
  videoId      String
  videoTitle   String
  videoThumb   String
  channelTitle String
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId, moveId])
}

model Submission {
  id        String   @id @default(cuid())
  userId    String
  moveId    String?
  moveName  String
  videoUrl  String
  videoId   String
  note      String?
  status    String   @default("pending")
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  move Move? @relation(fields: [moveId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
